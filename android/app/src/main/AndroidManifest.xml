<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

  <!-- Android 13+ notifications runtime permission -->
  <uses-permission
      android:name="android.permission.POST_NOTIFICATIONS"
      tools:targetApi="33" />

  <!-- Network access for your remote URL -->
  <uses-permission android:name="android.permission.INTERNET" />

  <!-- Optional: not strictly required, but harmless and clarifies intent -->
  <uses-permission android:name="android.permission.USE_BIOMETRIC" />
  <uses-permission android:name="android.permission.USE_FINGERPRINT" />

  <!-- 🔴 Force-remove Advertising ID permission contributed by SDKs -->
  <uses-permission
      android:name="com.google.android.gms.permission.AD_ID"
      tools:node="remove" />

  <application
      android:allowBackup="true"
      android:icon="@mipmap/ic_launcher"
      android:label="@string/app_name"
      android:roundIcon="@mipmap/ic_launcher_round"
      android:supportsRtl="true"
      android:theme="@style/AppTheme">

    <!-- Optional: enable WebView debugging on debug builds -->
    <meta-data
        android:name="pc.enable_webview_debugging"
        android:value="true" />

   <activity
    android:name=".MainActivity"
    android:label="@string/title_activity_main"
    android:theme="@style/AppTheme.NoActionBarLaunch"
    android:launchMode="singleTask"
    android:exported="true"
    android:windowSoftInputMode="adjustPan"
    android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation">

      <!-- ✅ Launcher intent-filter so the app shows in the app drawer -->
      <intent-filter>
        <action android:name="android.intent.action.MAIN" />
        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>

      <!-- ourglp1://oauth-complete?... (with host) -->
      <intent-filter>
        <action android:name="android.intent.action.VIEW" />
        <category android:name="android.intent.category.DEFAULT" />
        <category android:name="android.intent.category.BROWSABLE" />
        <data
            android:scheme="ourglp1"
            android:host="oauth-complete" />
      </intent-filter>

      <!-- ourglp1:/oauth-complete?... (no host, path prefix) -->
      <intent-filter
          tools:ignore="AppLinkUrlError">
        <action android:name="android.intent.action.VIEW" />
        <category android:name="android.intent.category.DEFAULT" />
        <category android:name="android.intent.category.BROWSABLE" />
        <data
            android:scheme="ourglp1"
            android:pathPrefix="/oauth-complete" />
      </intent-filter>

    </activity>

    <provider
        android:name="androidx.core.content.FileProvider"
        android:authorities="${applicationId}.fileprovider"
        android:exported="false"
        android:grantUriPermissions="true">
      <meta-data
          android:name="android.support.FILE_PROVIDER_PATHS"
          android:resource="@xml/file_paths" />
    </provider>
  </application>

</manifest>


